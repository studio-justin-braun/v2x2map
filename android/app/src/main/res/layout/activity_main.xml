<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimaryContainer"
        app:title="@string/app_name"
        app:menu="@menu/menu_main"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Status row -->
    <LinearLayout
        android:id="@+id/statusRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/usbStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/status_disconnected"
                android:textSize="12sp"/>
            <TextView
                android:id="@+id/btStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/bt_status_disconnected"
                android:textSize="12sp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/totalCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:textSize="12sp"
            tools:text="total 0"/>

        <TextView
            android:id="@+id/rateCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            tools:text="0/min"/>
    </LinearLayout>

    <!-- Connection action row: USB + BT only, per design -->
    <LinearLayout
        android:id="@+id/controls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/statusRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConnect"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="@string/connect"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConnectBt"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/connect_bt"/>
    </LinearLayout>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/logSplit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.70"/>

    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/controls"
        app:layout_constraintBottom_toTopOf="@id/logHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabLocate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="14dp"
        android:contentDescription="@string/locate"
        app:srcCompat="@drawable/ic_my_location"
        app:layout_constraintEnd_toEndOf="@id/map"
        app:layout_constraintBottom_toBottomOf="@id/map"/>

    <TextView
        android:id="@+id/logHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="6dp"
        android:background="?attr/colorSurfaceContainer"
        android:text="@string/frames_log_header"
        android:textAllCaps="true"
        android:textSize="11sp"
        app:layout_constraintTop_toTopOf="@id/logSplit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/log"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/logHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/emptyLog"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="14dp"
        android:gravity="center"
        android:text="@string/empty_log"
        android:textSize="12sp"
        app:layout_constraintTop_toTopOf="@id/log"
        app:layout_constraintBottom_toBottomOf="@id/log"
        app:layout_constraintStart_toStartOf="@id/log"
        app:layout_constraintEnd_toEndOf="@id/log"/>

</androidx.constraintlayout.widget.ConstraintLayout>
